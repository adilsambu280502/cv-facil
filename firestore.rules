rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Boilerplate for validation
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'createdAt', 'updatedAt'])
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidCV(data) {
      return data.keys().hasAll(['title', 'data', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 150
        && data.data is map 
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      allow delete: if false;

      match /cvs/{cvId} {
        allow read: if isOwner(userId) && isValidId(userId) && isValidId(cvId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(cvId)
                      && isValidCV(incoming())
                      && incoming().createdAt == request.time
                      && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(cvId)
                      && isValidCV(incoming())
                      && incoming().createdAt == existing().createdAt
                      && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(cvId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
